{
  "functions": {
    "src/app/api/discharge/generate/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/translation/request/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/demo/generate/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/**": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
